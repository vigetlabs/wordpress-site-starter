{
  "name": "image-caption",
  "title": "Image with Caption",
  "description": "Displays the Image with Caption Component.",
  "icon": "format-image",
  "category": "components",
  "textdomain": "wp-starter",
  "keywords": [ "photo", "upload", "media", "picture", "image", "caption" ],
  "allowedBlocks": [ "core/image" ],
  "attributes": {
    "templateLock": {
      "type": "string",
      "default": "contentOnly"
    }
  },
  "supports": {
    "jsx": true,
    "mode": false,
    "alignWide": true,
    "color": {
      "background": true
    },
    "layout": {
      "default": {
        "type": "constrained"
      }
    },
    "lock": {
      "move": true,
      "remove": false
    },
    "spacing": {
      "margin": [ "top", "bottom" ]
    }
  },
  "acf": {
    "mode": "preview"
  }
}
