{
  "name": "alert-banner",
  "title": "Alert Banner",
  "description": "Displays the Alert Banner Component.",
  "icon": "bell",
  "category": "components",
  "textdomain": "wp-starter",
  "keywords": [ "notification", "alert", "banner", "information", "bar", "important", "dismiss" ],
  "allowedBlocks": [ "core/paragraph","core/button" ],
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "block_id": {
      "type": "string",
      "default": ""
    },
    "templateLock": {
      "type": "string",
      "default": "contentOnly"
    },
    "backgroundColor": {
      "type": "string",
      "default": "dark-black"
    }
  },
  "styles": [
    {
      "name": "default",
      "label": "Default",
      "isDefault": true
    },
    {
      "name": "dismissible",
      "label": "Dismissible"
    }
  ],
  "supports": {
    "jsx": true,
    "mode": false,
    "alignWide": true,
    "anchor": true,
    "color": {
      "background": true
    },
    "layout": {
      "default": {
        "type": "constrained"
      },
      "allowOrientation": false,
      "allowCustomContentAndWideSize": false
    },
    "lock": {
      "move": true,
      "remove": false
    }
  },
  "acf": {
    "mode": "preview"
  }
}
