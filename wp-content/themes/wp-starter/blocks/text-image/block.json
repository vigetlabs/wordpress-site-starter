{
  "name": "text-image",
  "title": "Text & Image",
  "description": "Displays the Text & Image Component.",
  "icon": "align-left",
  "category": "components",
  "textdomain": "wp-starter",
  "keywords": [ "photo", "upload", "media", "picture", "image", "align", "left", "right", "content", "text" ],
  "allowedBlocks": [ "core/media-text", "core/paragraph", "core/heading", "core/group" ],
  "attributes": {
    "templateLock": {
      "type": "string",
      "default": "contentOnly"
    }
  },
  "supports": {
    "jsx": true,
    "mode": false,
    "alignWide": true,
    "color": {
      "background": true
    },
    "spacing": {
      "padding": [ "top", "bottom" ]
    },
    "layout": {
      "default": {
        "type": "constrained"
      },
      "allowOrientation": false,
      "allowCustomContentAndWideSize": false
    },
    "lock": {
      "move": true,
      "remove": false
    },
    "mediaPosition": {
      "transformations": [
        {
          "core/media-text": {
            "attributes": {
              "mediaPosition": {
                "left": "left",
                "right": "right"
              }
            }
          }
        }
      ]
    }
  },
  "acf": {
    "mode": "preview"
  }
}
