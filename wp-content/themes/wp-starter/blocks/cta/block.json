{
  "name": "cta",
  "title": "Call to Action",
  "description": "Displays the Call to Action Component.",
  "icon": "megaphone",
  "category": "components",
  "textdomain": "wp-starter",
  "keywords": [ "cta", "button", "heading", "section" ],
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "templateLock": {
      "type": "string",
      "default": "contentOnly"
    },
    "style": {
      "type": "object",
      "default": {
        "background": {
          "backgroundSize": "cover",
          "backgroundPosition": "50% 50%"
        }
      }
    }
  },
  "supports": {
    "jsx": true,
    "mode": false,
    "alignWide": true,
    "color": {
      "background": true
    },
    "background": {
      "backgroundImage": true,
      "backgroundSize": true
    },
    "innerContainer": false,
    "layout": {
      "default": {
        "type": "constrained",
        "justifyContent": "center"
      },
      "allowOrientation": false,
      "allowCustomContentAndWideSize": false
    },
    "lock": {
      "move": true,
      "remove": false
    },
    "spacing": {
      "padding": [ "top", "bottom" ]
    }
  },
  "acf": {
    "mode": "preview"
  }
}
